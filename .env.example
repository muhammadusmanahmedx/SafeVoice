# Supabase (https://supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: Jitsi video meetings (free, no signup or card required).
# Defaults to jitsi.riot.im, which is embeddable AND allows anonymous rooms
# (no login / no "waiting for a moderator"). Avoid meet.jit.si (forces moderator
# login) and meet.ffmuc.net (blocks iframe embedding).
# JITSI_DOMAIN=jitsi.riot.im

# Optional: Capacitor native app — production URL loaded in WebView (see README)
# CAPACITOR_SERVER_URL=https://your-app.vercel.app
# Optional: Android APK download URL (defaults to /downloads/safevoice.apk after npm run cap:copy-apk)
# NEXT_PUBLIC_ANDROID_APK_URL=/downloads/safevoice.apk
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
